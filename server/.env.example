# DoorDash Drive API Credentials
# Get these from https://developer.doordash.com/portal/credentials
DOORDASH_DEVELOPER_ID=your_developer_id_here
DOORDASH_KEY_ID=your_key_id_here
DOORDASH_SIGNING_SECRET=your_signing_secret_here

# Server
PORT=3001
WEBHOOK_SECRET=your_webhook_secret_here

# CORS — comma-separated list of allowed frontend origins
# In production, set this to your actual domain(s)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Environment
NODE_ENV=development
